  "keyFeatures": [
    "Server-side characters (SSC) with inventory management and data persistence",
    "Permission-based group system for fine-grained player access control",
    "Anti-cheat and exploit protection",
    "In-game and console command system with extensible API",
    "REST API for remote server management and integrations",
    "Ban and moderation tools with IP, UUID, and account tracking",
    "Region-based build protection",
    "Plugin management via NuGet packages",
    "Docker support for containerized deployments",
    "Internationalization (i18n) support"
  ],
  "publicApiSurface": [
    "TShockAPI.TShock (main plugin class)",
    "TShockAPI.TSPlayer (player management)",
    "TShockAPI.Commands (command registration and execution)",
    "TShockAPI.Permissions (permission nodes)",
    "TShockAPI.Hooks.PlayerHooks (player lifecycle events)",
    "TShockAPI.Hooks.GeneralHooks (general server events)",
    "TShockAPI.Hooks.AccountHooks (account events)",
    "TShockAPI.Hooks.RegionHooks (region events)",
    "TShockAPI.DB (database abstraction layer)",
    "TShockAPI.Rest (REST API routing and authentication)",
    "TShockAPI.Group (group and permission management)",
    "TShockAPI.Utils (utility methods)",
    "REST /v3/bans/* (ban management endpoints)",
    "REST /v2/groups/* (group management endpoints)",
    "REST /v2/players/* (player management endpoints)",
    "REST /v3/server/* (server management endpoints)"
  ]
}
